<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.logicgate.ui.MainController">
    <stylesheets>
        <URL value="@main.css" />
    </stylesheets>
    <top>
        <MenuBar fx:id="mainMenuBar" onMousePressed="#clearFocusFromCanvas">
            <Menu text="파일">
                <MenuItem text="프로젝트 저장" onAction="#saveProject"/>
                <SeparatorMenuItem/>
                <MenuItem text="JSON 내보내기" onAction="#exportJson"/>
                <MenuItem text="JSON 가져오기" onAction="#importJson"/>
                <SeparatorMenuItem/>
                <MenuItem text="종료" onAction="#shutdown"/>
            </Menu>
            <Menu text="편집">
                <MenuItem text="모두 지우기" onAction="#clearCircuit"/>
            </Menu>
            <Menu text="설정">
                <MenuItem text="모드 관리자" onAction="#openModManager"/>
            </Menu>
            <Menu text="도움말">
                <MenuItem text="정보"/>
            </Menu>
        </MenuBar>
    </top>
    <center>
        <SplitPane dividerPositions="0.2, 0.8">
            <items>
                <!-- 좌측 사이드바: 부품 상자 -->
                <VBox fx:id="leftSidebar" spacing="10" styleClass="sidebar" minWidth="160" maxWidth="500" onMousePressed="#clearFocusFromCanvas">
                    <padding>
                        <Insets top="20" right="10" bottom="20" left="10"/>
                    </padding>
                    
                    <Label text="부품 상자" styleClass="section-header"/>
                    <TreeView fx:id="componentTreeView" focusTraversable="false" VBox.vgrow="ALWAYS" />
                    
                    <Label text="사용법" styleClass="usage-label"/>
                    <Label text="클릭: 선택" styleClass="usage-label"/>
                    <Label text="Del/BS: 삭제" styleClass="usage-label"/>
                    <Label text="드래그: 이동" styleClass="usage-label"/>
                    <Label text="핀 드래그: 선 긋기" styleClass="usage-label"/>
                </VBox>
                
                <!-- 중앙: 캔버스 영역 -->
                <Pane fx:id="canvasPane" styleClass="canvas-area">
                    <Canvas fx:id="simulationCanvas" />
                </Pane>

                <!-- 우측 사이드바: 속성창 -->
                <VBox fx:id="rightSidebar" spacing="10" styleClass="sidebar" minWidth="160" maxWidth="400" onMousePressed="#clearFocusFromCanvas">
                    <padding>
                        <Insets top="20" right="10" bottom="20" left="10"/>
                    </padding>
                    
                    <Label text="컴포넌트 검색" styleClass="section-header"/>
                    <VBox spacing="5">
                        <TextField fx:id="searchTextField" promptText="라벨로 검색..."/>
                        <ListView fx:id="searchResultsListView" prefHeight="200" visible="false" managed="false"/>
                    </VBox>
                    
                    <Separator/>
                    
                    <Label text="컴포넌트 속성" styleClass="section-header"/>
                    <VBox fx:id="propertyPane" spacing="10" styleClass="property-section">
                        <VBox spacing="5">
                            <Label text="라벨 이름" styleClass="property-label"/>
                            <TextField fx:id="labelTextField" focusTraversable="false"/>
                        </VBox>
                        <CheckBox fx:id="showLabelCheckBox" text="화면에 라벨 표시" focusTraversable="false"/>
                    </VBox>
                </VBox>
            </items>
        </SplitPane>
    </center>
    <bottom>
        <VBox>
            <ListView fx:id="consoleListView" prefHeight="150" visible="false" managed="false" styleClass="console-list"/>
            <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="3" right="10" bottom="3" left="10"/>
                </padding>
                <Button fx:id="errorButton" text="0 로그" onAction="#toggleConsole" styleClass="status-btn"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Logic Gate Simulator v1.0" styleClass="status-label"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
