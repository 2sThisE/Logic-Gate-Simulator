<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.logicgate.ui.LauncherController" prefWidth="800" prefHeight="500">
    <stylesheets>
        <URL value="@launcher.css" />
    </stylesheets>

    <!-- Left Sidebar -->
    <VBox styleClass="sidebar" prefWidth="250" spacing="10">
        <padding>
            <Insets top="30" right="20" bottom="30" left="20"/>
        </padding>
        <Label text="Logic Gate Simulator" styleClass="app-title"/>
        
        <VBox spacing="5">
            <Button text="최근 프로젝트" onAction="#showRecentProjects" styleClass="menu-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="새 프로젝트" onAction="#showNewProject" styleClass="menu-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="프로젝트 불러오기" onAction="#openExistingProject" styleClass="menu-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
        </VBox>
        
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="종료" onAction="#exitApp" styleClass="menu-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
    </VBox>

    <!-- Main Content Area -->
    <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS" styleClass="content-area">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>
        
        <!-- Recent Projects View -->
        <VBox fx:id="recentProjectsView" spacing="15" visible="true">
            <Label text="최근 프로젝트 열기" styleClass="section-title"/>
            <ListView fx:id="recentProjectsList" VBox.vgrow="ALWAYS" styleClass="recent-list"/>
            <Label text="프로젝트를 더블 클릭하여 엽니다." styleClass="help-text"/>
        </VBox>

        <!-- New Project View -->
        <VBox fx:id="newProjectView" spacing="20" visible="false">
            <Label text="새 프로젝트 만들기" styleClass="section-title"/>
            
            <VBox spacing="5">
                <Label text="프로젝트 이름" styleClass="field-label"/>
                <TextField fx:id="projectNameField" promptText="예: MyCircuit" styleClass="input-field"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="위치" styleClass="field-label"/>
                <HBox spacing="10">
                    <TextField fx:id="projectLocationField" promptText="경로 선택..." HBox.hgrow="ALWAYS" styleClass="input-field"/>
                    <Button text="..." onAction="#browseNewProjectLocation" styleClass="browse-btn"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button text="취소" onAction="#showRecentProjects" styleClass="cancel-btn"/>
                <Button text="만들기" onAction="#createNewProject" styleClass="primary-btn"/>
            </HBox>
        </VBox>
        
    </StackPane>
</HBox>