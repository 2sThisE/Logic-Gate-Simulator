<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="500" prefWidth="800" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.logicgate.ui.LauncherController">
    <stylesheets>
        <URL value="@launcher.css" />
    </stylesheets>

    <!-- Left Sidebar -->
    <VBox prefHeight="500.0" prefWidth="226.0" spacing="10" styleClass="sidebar">
        <padding>
            <Insets bottom="30" left="20" right="20" top="30" />
        </padding>
        <Label prefHeight="43.0" prefWidth="194.0" styleClass="app-title" text="Logic Gate Simulator" />
        
        <VBox spacing="5">
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#showRecentProjects" styleClass="menu-btn" text="최근 프로젝트" />
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#showNewProject" styleClass="menu-btn" text="새 프로젝트" />
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#openExistingProject" styleClass="menu-btn" text="프로젝트 불러오기" />
        </VBox>
        
        <Region VBox.vgrow="ALWAYS" />
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#exitApp" styleClass="menu-btn" text="종료" />
    </VBox>

    <!-- Main Content Area -->
    <StackPane fx:id="contentArea" styleClass="content-area" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="30" left="30" right="30" top="30" />
        </padding>
        
        <!-- Recent Projects View -->
        <VBox fx:id="recentProjectsView" spacing="15" visible="true">
            <Label styleClass="section-title" text="최근 프로젝트 열기" />
            <ListView fx:id="recentProjectsList" styleClass="recent-list" VBox.vgrow="ALWAYS" />
            <Label styleClass="help-text" text="프로젝트를 더블 클릭하여 엽니다." />
        </VBox>

        <!-- New Project View -->
        <VBox fx:id="newProjectView" spacing="20" visible="false">
            <Label styleClass="section-title" text="새 프로젝트 만들기" />
            
            <VBox spacing="5">
                <Label styleClass="field-label" text="프로젝트 이름" />
                <TextField fx:id="projectNameField" promptText="예: MyCircuit" styleClass="input-field" />
            </VBox>
            
            <VBox spacing="5">
                <Label styleClass="field-label" text="위치" />
                <HBox spacing="10">
                    <TextField fx:id="projectLocationField" promptText="경로 선택..." styleClass="input-field" HBox.hgrow="ALWAYS" />
                    <Button onAction="#browseNewProjectLocation" styleClass="browse-btn" text="..." />
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#showRecentProjects" styleClass="cancel-btn" text="취소" />
                <Button onAction="#createNewProject" styleClass="primary-btn" text="만들기" />
            </HBox>
        </VBox>
        
    </StackPane>
</HBox>
