<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.logicgate.ui.MainController">
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #202020;">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="실시간 논리 회로 시뮬레이터 (인터랙티브 캔버스)" textFill="WHITE" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </VBox>
    </top>
    <left>
        <VBox spacing="10" style="-fx-background-color: #333333;" prefWidth="120">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>
            <Label text="프로젝트" textFill="WHITE" style="-fx-font-weight: bold;"/>
            <Button text="저장하기" prefWidth="100" onAction="#saveProject" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
            <Button text="불러오기" prefWidth="100" onAction="#loadProject" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
            
            <Label text="부품 상자" textFill="WHITE" style="-fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
            <Button text="Switch" prefWidth="100" onAction="#addSwitch"/>
            <Button text="LED" prefWidth="100" onAction="#addLed"/>
            <Button text="Joint (1:4)" prefWidth="100" onAction="#addJoint"/>
            <Button text="AND Gate" prefWidth="100" onAction="#addAndGate"/>
            <Button text="OR Gate" prefWidth="100" onAction="#addOrGate"/>
            <Button text="NOT Gate" prefWidth="100" onAction="#addNotGate"/>
            <Button text="XOR Gate" prefWidth="100" onAction="#addXorGate"/>
            <Button text="NOR Gate" prefWidth="100" onAction="#addNorGate"/>
            <!-- To keep FXML simple, more can be added later -->
            <Label text="사용법" textFill="GRAY" style="-fx-font-size: 10px;"/>
            <Label text="클릭: 선택" textFill="GRAY" style="-fx-font-size: 10px;"/>
            <Label text="Del/BS: 삭제" textFill="GRAY" style="-fx-font-size: 10px;"/>
            <Label text="드래그: 이동" textFill="GRAY" style="-fx-font-size: 10px;"/>
            <Label text="핀 드래그: 선 긋기" textFill="GRAY" style="-fx-font-size: 10px;"/>
        </VBox>
    </left>
    <center>
        <Pane fx:id="canvasPane" style="-fx-background-color: #2B2B2B;">
            <Canvas fx:id="simulationCanvas" />
        </Pane>
    </center>
</BorderPane>
